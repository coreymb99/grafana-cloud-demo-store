OTEL_SERVICE_NAME=checkout-service
SERVICE_NAMESPACE=northstar-mercantile
SERVICE_VERSION=0.1.0
DEPLOYMENT_ENVIRONMENT=demo

# Paste these from Grafana Cloud -> OpenTelemetry -> Configure.
# For Python, Grafana's docs note that the header value should use "Basic%20" instead of "Basic ".
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-us-east-0.grafana.net/otlp
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic%20<base64-instanceid:token>

PAYMENT_DEGRADATION=1.0
PAYMENT_FAILURE_RATE=0.08
INVENTORY_SPIKE_MULTIPLIER=1.0
